<CompuCell3D Revision="2" Version="4.6.0">
   
   <Metadata>
      
      <!-- Basic properties simulation -->
      <NumberOfProcessors>4</NumberOfProcessors>
      <DebugOutputFrequency>10</DebugOutputFrequency>
      <!-- <NonParallelModule Name="Potts"/> -->
   </Metadata>
   
   <Potts>
      
      <!-- Basic properties of CPM (GGH) algorithm -->
      <Dimensions x="250" y="250" z="250"/>
      <Steps>701</Steps>
      <Temperature>10.0</Temperature>
      <NeighborOrder>4</NeighborOrder>
      <!-- <LatticeType>Hexagonal</LatticeType> -->
      <!-- <Boundary_x>Periodic</Boundary_x> -->
      <!-- <Boundary_y>Periodic</Boundary_y> -->
      <!-- <Boundary_z>Periodic</Boundary_z> -->
      <!--<RandomSeed>167475</RandomSeed>-->
   </Potts>
   
   <Plugin Name="CellType">
      
      <!-- Listing all cell types in the simulation -->
      <CellType TypeId="0" TypeName="Medium"/>
      <CellType TypeId="1" TypeName="LC"/>
      <CellType TypeId="2" TypeName="FC"/>
   </Plugin>
   
   <Plugin Name="Volume"/>
   
   <Plugin Name="CenterOfMass">
      
      <!-- Module tracking center of mass of each cell --> 

   </Plugin>
   
   <Plugin Name="NeighborTracker">
      
      <!-- Module tracking neighboring cells of each cell -->  

   </Plugin>
   
   <Plugin Name="MomentOfInertia">
      
      <!-- Module tracking moment of inertia of each cell -->
   </Plugin>
   
   <Plugin Name="Contact">
      <!-- Specification of adhesion energies in order of least to greatest -->
      <Energy Type1="Medium" Type2="Medium">0.0</Energy> 
      <Energy Type1="Medium" Type2="LC">2.0</Energy> 
      <Energy Type1="LC" Type2="FC" id="J_LF">2.0</Energy>
      <Energy Type1="FC" Type2="FC">5.0</Energy>
      <Energy Type1="Medium" Type2="FC">10.0</Energy>
      <Energy Type1="LC" Type2="LC">16.0</Energy>
      <NeighborOrder>4</NeighborOrder>
   </Plugin>
   
   <Plugin Name="Chemotaxis">
      
      <ChemicalField Name="MV">
        <ChemotaxisByType Lambda="15" Type="LC" id="lambda_chem"/> 
      </ChemicalField>  
    </Plugin>
   
   <Steppable Type="DiffusionSolverFE">
      
      <!-- Specification of PDE solvers -->
      <DiffusionField Name="MV">
         <DiffusionData>
            <FieldName>MV</FieldName>
            <GlobalDiffusionConstant>0</GlobalDiffusionConstant>
            <GlobalDecayConstant>0</GlobalDecayConstant>
             <DiffusionCoefficient CellType="LC">0.0</DiffusionCoefficient>
            <DiffusionCoefficient CellType="FC">0.0</DiffusionCoefficient>
            <DecayCoefficient CellType="LC">0.0000</DecayCoefficient>
            <DecayCoefficient CellType="FC">0.0000</DecayCoefficient>
         </DiffusionData>
         <SecretionData>
           
            <Secretion Type="LC">0.0</Secretion>
            <Secretion Type="FC">0.0</Secretion>

         </SecretionData>
         <BoundaryConditions>
            <Plane Axis="X">
               <ConstantDerivative PlanePosition="Min" Value="10.0"/>
               <ConstantDerivative PlanePosition="Max" Value="5.0"/>
            </Plane>
            <Plane Axis="Y">
               <ConstantDerivative PlanePosition="Min" Value="10.0"/>
               <ConstantDerivative PlanePosition="Max" Value="5.0"/>
            </Plane>
            <Plane Axis="Z">
               <ConstantDerivative PlanePosition="Min" Value="10.0"/>
               <ConstantDerivative PlanePosition="Max" Value="5.0"/>
  
            </Plane>
         </BoundaryConditions>
      </DiffusionField>
   </Steppable>
   

</CompuCell3D>
